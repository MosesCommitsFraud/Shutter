{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shutter",
  "version": "0.2.0",
  "identifier": "com.shutter.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Shutter",
        "width": 750,
        "height": 500,
        "minWidth": 680,
        "minHeight": 460,
        "transparent": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 14,
          "y": 30
        },
        "visible": false,
        "center": true,
        "contentProtected": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
